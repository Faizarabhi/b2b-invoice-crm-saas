spring:
  application:
    name: invoicecrm

  datasource:
    url: jdbc:postgresql://localhost:5432/b2b_invoice_crm
    username: postgres
    password: postgres
    driver-class-name: org.postgresql.Driver

  jpa:
    hibernate:
      ddl-auto: validate
    show-sql: true
    properties:
      hibernate:
        format_sql: true

  flyway:
    enabled: true
    locations: classpath:db/migration

server:
  port: 8080
